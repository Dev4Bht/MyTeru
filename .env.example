# ── Database ─────────────────────────────────────────────────────────────
# Port is non-default (5433) so the docker-compose dev stack doesn't collide
# with other Postgres instances already running on this machine. Adjust
# here (and in docker/docker-compose.yml) if you'd rather use the standard
# port. In production (Netlify), DATABASE_URL is provided automatically by
# Netlify DB — this value is only used for local development.
DATABASE_URL="postgresql://druksave:druksave@localhost:5433/druksave?schema=public"

# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=4000
API_GLOBAL_PREFIX="api"
WEB_APP_URL="http://localhost:3000"
API_BASE_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000"

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_REFRESH_TTL="30d"

# ── Password hashing (Argon2id) ─────────────────────────────────────────
ARGON2_MEMORY_COST=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1

# ── OTP ──────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_SENDS_PER_HOUR=5

# ── Account lockout / brute force protection ────────────────────────────
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── SMS provider (Twilio for now; swap for Bhutan Telecom/TashiCell later) ─
SMS_PROVIDER="twilio"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM_NUMBER=""
# When true, OTPs are logged to the console instead of sent via SMS (local dev only)
SMS_DEV_MODE=true

# ── Next.js (apps/web) ───────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000/api"
