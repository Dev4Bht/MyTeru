# ── Database ─────────────────────────────────────────────────────────────
# Port is non-default (5433) so the docker-compose dev stack doesn't collide
# with other Postgres instances already running on this machine. Adjust
# here (and in docker/docker-compose.yml) if you'd rather use the standard
# port. On Render, DATABASE_URL is wired automatically from the managed
# Postgres resource (see render.yaml) — this value is only for local dev.
DATABASE_URL="postgresql://druksave:druksave@localhost:5433/druksave?schema=public"

# ── App ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
API_PORT=4000
API_GLOBAL_PREFIX="api"
API_BASE_URL="http://localhost:4000"
CORS_ORIGINS="http://localhost:3000"

# ── JWT ──────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_REFRESH_TTL="30d"

# ── Google Sign-In ───────────────────────────────────────────────────────
# Create an OAuth 2.0 Client ID (type "Web application") at
# https://console.cloud.google.com/apis/credentials, add both
# http://localhost:3000 and your deployed web URL under "Authorized
# JavaScript origins", then paste the client ID in both places below (the
# API verifies tokens were issued for this same client; the web app needs
# the NEXT_PUBLIC_ copy to render the Sign-In button client-side).
GOOGLE_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
