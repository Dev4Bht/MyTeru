// DrukSave — Prisma schema
// Covers the full product surface. Only auth/identity models carry business
// logic in Phase 1; the money-domain and intelligence/ops models exist now so
// later phases are additive migrations, not schema fights.

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  USER
  SUPPORT
  ADMIN
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum TransactionSource {
  MANUAL
  RECURRING
  IMPORTED
  VOICE
  OCR
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  YEARLY
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum InsightType {
  DAILY
  WEEKLY
  MONTHLY
  ALERT
}

enum PredictionType {
  CASH_FLOW_FORECAST
  GOAL_COMPLETION
  FUTURE_BALANCE
  FINANCIAL_HEALTH_SCORE
}

enum NotificationChannel {
  SMS
  PUSH
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  READ
}

enum ReportType {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum ReportFormat {
  PDF
  EXCEL
  CSV
}

// ─────────────────────────────────────────────────────────────────────────
// Auth / Identity
// ─────────────────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid())
  email       String    @unique // from the verified Google account — the only identity we trust
  googleId    String    @unique // Google's "sub" claim
  role        Role      @default(USER)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  profile           Profile?
  devices           Device[]
  sessions          Session[]
  auditLogs         AuditLog[]
  settings          Setting?

  transactions          Transaction[]
  categories            Category[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]
  goals                 Goal[]
  receipts              Receipt[]
  analytics              Analytics[]
  insights               Insight[]
  aiPredictions          AiPrediction[]
  notifications          Notification[]
  reports                Report[]

  @@map("users")
}

model Profile {
  id           String    @id @default(uuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  phone        String?   @unique // E.164, e.g. +97517123456 — optional, for future SMS notifications only, not auth
  dzongkhag    String? // Bhutanese district, e.g. Thimphu, Paro
  occupation   String? // e.g. Government Employee, Farmer, Taxi Driver
  avatarUrl    String? // from the Google account picture, editable later
  dateOfBirth  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@map("profiles")
}

model Device {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId     String // client-generated fingerprint
  name         String? // e.g. "iPhone 13", "Chrome on Windows"
  platform     String? // ios | android | web
  lastSeenAt   DateTime  @default(now())
  lastIp       String?
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  sessions     Session[]

  @@unique([userId, deviceId])
  @@map("devices")
}

model Session {
  id                String    @id @default(uuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceId          String?
  device            Device?   @relation(fields: [deviceId], references: [id], onDelete: SetNull)
  refreshTokenHash  String // hash of the refresh token, never the raw token
  userAgent         String?
  ip                String?
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedBySessionId String?
  createdAt         DateTime  @default(now())

  @@index([userId])
  @@map("sessions")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // e.g. "auth.login.success", "auth.google.linked"
  metadata   Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId, action])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// Money domain (schema only until Phase 2+)
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(uuid())
  userId    String? // null = system default category shared across all users
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // e.g. "Food & Dining", "Transport", "Festivals & Losar"
  icon      String?
  color     String?
  type      TransactionType
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets                Budget[]

  @@index([userId])
  @@map("categories")
}

model Merchant {
  id           String   @id @default(uuid())
  name         String // e.g. "Bhutan Telecom", "Zombala", "Weekend Market"
  normalizedName String @unique
  category     String?
  createdAt    DateTime @default(now())

  transactions Transaction[]

  @@map("merchants")
}

model Transaction {
  id          String             @id @default(uuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amountNu    Decimal            @db.Decimal(12, 2) // Ngultrum, always positive; sign implied by type
  categoryId  String?
  category    Category?          @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  merchantId  String?
  merchant    Merchant?          @relation(fields: [merchantId], references: [id], onDelete: SetNull)
  description String?
  source      TransactionSource  @default(MANUAL)
  recurringId String?
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id], onDelete: SetNull)
  receiptId   String?             @unique
  receipt     Receipt?            @relation(fields: [receiptId], references: [id], onDelete: SetNull)
  occurredAt  DateTime
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@index([userId, occurredAt])
  @@index([userId, type])
  @@map("transactions")
}

model RecurringTransaction {
  id          String              @id @default(uuid())
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        TransactionType
  amountNu    Decimal             @db.Decimal(12, 2)
  categoryId  String?
  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  description String? // e.g. "Government Salary", "Bhutan Telecom Postpaid Bill"
  frequency   RecurrenceFrequency
  startDate   DateTime
  endDate     DateTime?
  nextRunAt   DateTime
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  transactions Transaction[]

  @@index([userId, isActive])
  @@map("recurring_transactions")
}

model Budget {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  period     BudgetPeriod
  limitNu    Decimal      @db.Decimal(12, 2)
  startDate  DateTime
  endDate    DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  @@index([userId, period])
  @@map("budgets")
}

model Goal {
  id             String     @id @default(uuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String // e.g. "Dream Laptop", "Emergency Fund", "Losar Trip Home"
  targetAmountNu Decimal    @db.Decimal(12, 2)
  savedAmountNu  Decimal    @db.Decimal(12, 2) @default(0)
  targetDate     DateTime?
  status         GoalStatus @default(ACTIVE)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  contributions GoalContribution[]

  @@index([userId, status])
  @@map("goals")
}

model GoalContribution {
  id          String   @id @default(uuid())
  goalId      String
  goal        Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amountNu    Decimal  @db.Decimal(12, 2)
  note        String?
  contributedAt DateTime @default(now())

  @@index([goalId])
  @@map("goal_contributions")
}

model Receipt {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  imageUrl    String
  ocrRawText  String?
  ocrAmountNu Decimal? @db.Decimal(12, 2)
  ocrMerchant String?
  ocrDate     DateTime?
  createdAt   DateTime @default(now())

  transaction Transaction?
  attachments Attachment[]

  @@index([userId])
  @@map("receipts")
}

model Attachment {
  id        String   @id @default(uuid())
  receiptId String?
  receipt   Receipt? @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  reportId  String?
  report    Report?  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  fileUrl   String
  mimeType  String
  sizeBytes Int
  createdAt DateTime @default(now())

  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────────────────
// Intelligence / Ops (schema only until Phase 5+)
// ─────────────────────────────────────────────────────────────────────────

model Analytics {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  periodStart   DateTime
  periodEnd     DateTime
  totalIncomeNu Decimal  @db.Decimal(12, 2)
  totalExpenseNu Decimal @db.Decimal(12, 2)
  savingsRateBp Int // basis points, e.g. 1250 = 12.50%
  healthScore   Int? // 0-100
  breakdown     Json? // category -> amount snapshot
  createdAt     DateTime @default(now())

  @@index([userId, periodStart])
  @@map("analytics")
}

model Insight {
  id         String      @id @default(uuid())
  userId     String
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       InsightType
  title      String
  body       String // natural-language explanation, e.g. "You spent Nu.2,300 more on dining this month."
  metadata   Json?
  isRead     Boolean     @default(false)
  createdAt  DateTime    @default(now())

  @@index([userId, createdAt])
  @@map("insights")
}

model AiPrediction {
  id          String         @id @default(uuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        PredictionType
  payload     Json // prediction-specific structured output
  confidence  Float? // 0.0 - 1.0
  validFrom   DateTime       @default(now())
  validUntil  DateTime?
  createdAt   DateTime       @default(now())

  @@index([userId, type])
  @@map("ai_predictions")
}

model Notification {
  id         String              @id @default(uuid())
  userId     String
  user       User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel    NotificationChannel
  status     NotificationStatus  @default(PENDING)
  title      String
  body       String
  metadata   Json?
  sentAt     DateTime?
  readAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId, status])
  @@map("notifications")
}

model Report {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       ReportType
  format     ReportFormat
  periodStart DateTime
  periodEnd   DateTime
  fileUrl    String?
  status     String       @default("PENDING") // PENDING | GENERATING | READY | FAILED
  createdAt  DateTime     @default(now())

  attachments Attachment[]

  @@index([userId, type])
  @@map("reports")
}

model Setting {
  id                  String   @id @default(uuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  language             String   @default("en") // en | dz
  theme                String   @default("system") // light | dark | system
  currency             String   @default("BTN")
  notifyBudgetExceeded Boolean  @default(true)
  notifyBillReminders  Boolean  @default(true)
  notifyGoalMilestones Boolean  @default(true)
  updatedAt            DateTime @updatedAt

  @@map("settings")
}
